###############################################################################
# Variables d'environnement
# Copier ce fichier en `.env` et remplir les vraies valeurs.
# Le fichier .env est dans .gitignore et ne sera jamais commité.
###############################################################################

# ===== Grafana =====
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ===== Alertes Discord =====
# Comment créer un webhook :
# 1. Dans Discord : Paramètres du salon > Intégrations > Webhooks > Nouveau webhook
# 2. Copier l'URL (format: https://discord.com/api/webhooks/ID/TOKEN)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/REMPLACER_ID/REMPLACER_TOKEN

# ===== Alertes Email =====
ALERT_EMAIL_TO=111562@ecole-it.com
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_FROM=111562@ecole-it.com
SMTP_USER=111562@ecole-it.com
