###############################################################################
# Variables d'environnement - exemple
# Copier ce fichier en `.env` et remplir les vraies valeurs.
# Le fichier .env est dans .gitignore et ne sera jamais commite.
###############################################################################

# ===== Application =====
JWT_SECRET=please-change-me-32-chars-minimum-secret

# ===== PostgreSQL =====
POSTGRES_USER=monitoring
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=monitoring

# ===== Grafana =====
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-this-password

# ===== AlertManager - Discord webhook =====
# Comment creer un webhook Discord :
# 1. Settings d'un channel > Integrations > Webhooks > New Webhook
# 2. Copier l'URL (format: https://discord.com/api/webhooks/ID/TOKEN)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE_WITH_YOUR_ID/REPLACE_WITH_YOUR_TOKEN

# ===== AlertManager - Email (Gmail SMTP exemple) =====
# Pour Gmail : creer un "App Password" dans Settings > Security > 2FA > App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=your-email@gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
ALERT_EMAIL_TO=yassinetaifi905@gmail.com
